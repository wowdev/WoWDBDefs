0x1 DEPRECATED_FORCE_NO_ANIMATION_BLEND_IN // use Blend Time Override : In Min&Max
0x2 DEPRECATED_FORCE_NO_ANIMATION_BLEND_OUT // use Blend Time Override: Out Min&Max
0x4 DO_NOT_USE_ADVANCED_PLAY_ON_SECONDARY_TRACK // Disrupts Blending
0x8 INSTEAD_OF_PLAYING_A_FALLBACK_ANIMATION_SKIP_SEGMENT
0x10 INSTEAD_OF_PLAYING_A_FALLBACK_ANIMATION_DONT_PLAY_KIT_AT_ALL
0x20 IF_MODEL_IS_MISSING_A_DESIRED_BONE_SET_USE_PARENT_OR_ANCESTOR_BONE_SET
0x40 IF_MODEL_IS_MISSING_A_DESIRED_BONE_SET_SKIP_SEGMENT
0x80 IF_MODEL_IS_MISSING_A_DESIRED_BONE_SET_DONT_PLAY_KIT_AT_ALL
0x100 PLAY_ON_ALL_CHILDREN_AND_DESCENDANT_BONE_SETS_AT_SAME_PRIORITY
0x200 IF_ANY_BONE_SET_IS_SUPPRESSED_BY_A_HIGHER_PRIORITY_SKIP_SEGMENT
0x400 IF_ALL_BONE_SETS_ARE_SUPPRESSED_BY_A_HIGHER_PRIORITY_SKIP_SEGMENT
0x800 IF_ANY_BONE_SET_IS_SUPPRESSED_BY_A_HIGHER_PRIORITY_STOP_KIT
0x1000 IF_ALL_BONE_SETS_ARE_SUPPRESSED_BY_A_HIGHER_PRIORITY_STOP_KIT
0x2000 WHEN_NO_LONGER_SUPPRESSED_BY_A_HIGHER_PRIORITY_RESTART_CURRENT_SEGMENT
0x4000 ADVANCED_PLAY_SEGMENT_EVEN_IF_BONE_SET_IS_MISSING // for animation mirroring
0x8000 ADVANCED_BLOCKS_SECONDARY_ANIMATION_WHEN_ACTIVE
0x10000 ADVANCED_DONT_RESTART_SEGMENT_IF_THE_ANIMATION_IS_UNCHANGED_FOLLOWING_A_SET
0x20000 IF_ANY_BONE_SET_IS_SUPPRESSED_BY_A_HIGHER_PRIORITY_SUPPRESS_SEGMENT
0x40000 INSTEAD_OF_FALLING_BACK_TO_THE_STAND_ANIMATION_SKIP_SEGMENT
0x80000 INSTEAD_OF_FALLING_BACK_TO_THE_STAND_ANIMATION_DONT_PLAY_KIT_AT_ALL
0x100000 WHEN_NO_LONGER_SUPPRESSED_BY_A_HIGHER_PRIORITY_RESTART_CURRENT_KIT
0x200000 SUPPRESS_ALL_SOUNDS_ORIGINATING_FROM_ANIMATION_EVENTS
0x400000 SUPPRESS_SOUNDS_ORIGINATING_FROM_COMBAT_ANIMATION_EVENTS
0x800000 FORCE_SHEATHED
0x1000000 FORCE_UNSHEATHED
0x2000000 MAINTAIN_INITIAL_FACING
0x4000000 AIM_ALONG_UNITS_SMOOTH_FACING
0x8000000 USE_MOD_CAST_SPEED
0x10000000 AIM_LEFT_ARM
0x20000000 AIM_RIGHT_ARM
0x40000000 DISABLE_ARM_AIMING
0x80000000 SPEED_UP_BASED_ON_PERCENTAGE_COMPLETE
